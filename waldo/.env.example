SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Prefer this in production (Render sets it automatically when a PostgreSQL service is linked)
DATABASE_URL=postgresql://waldo_user:change-me@127.0.0.1:5432/waldo

# Optional local fallback if DATABASE_URL is not set
POSTGRES_DB=waldo
POSTGRES_USER=waldo_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
